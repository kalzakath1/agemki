{
  "mcpServers": {
    "watcom-context": {
      "command": "node",
      "args": ["./mcp-servers/watcom-context/index.js"],
      "env": {
        "WATCOM_DOC_PATH": "./documentation/legacy/open-watcom-guide.pdf"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(wcc386*)",
      "Bash(wlink*)",
      "Bash(node mcp-servers/*)",
      "Bash(git *)"
    ],
    "deny": []
  }
}
